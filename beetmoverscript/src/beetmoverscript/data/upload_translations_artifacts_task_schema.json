{
  "title": "Taskcluster beetmover upload translations artifacts task schema",
  "type": "object",
  "properties": {
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object",
      "properties": {
        "releaseProperties": {
            "type": "object",
            "properties": {
                "appName": {
                    "type": "string"
                }
            },
            "required": [
                "appName"
            ]
        },
        "upstreamArtifacts": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "taskType": {
                        "type": "string"
                    },
                    "taskId": {
                        "type": "string"
                    },
                    "paths": {
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["taskId", "taskType", "paths"]
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "artifactMap": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "taskId": {
                        "type": "string"
                    },
                    "paths": {
                        "type": "object",
                        "minItems": 1,
                        "uniqueItems": true,
                        "properties": {
                            "destinations": {
                                "type": "array",
                                "minItems": 1,
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "taskId",
                    "paths"
                ]
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "maxRunTime": {
          "type": "number"
        }
      },
      "required": ["releaseProperties", "upstreamArtifacts", "artifactMap"]
    }
  },
  "required": ["payload", "dependencies"]
}
